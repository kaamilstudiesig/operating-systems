#include <stdio.h>

int main() {
    int n , temp;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    int at[n], bt[n] , ct[n] ,tat[n] , wt[n];

    for (int i = 0; i < n; i++) {
        printf("\nEnter arrival time of process %d: ", i + 1);
        scanf("%d", &at[i]);
        printf("Enter burst time of process %d: ", i + 1);
        scanf("%d", &bt[i]);
    }
    for(int i = 0 ; i < n-1 ; i++){
        for( int j = i+1 ; j < n ; j++){
            if(at[i] > at[j]){
                temp = at[i];
                at[i] = at[j];
                at[j] = temp;

                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }
        }
    }
    int time = 0;
    for ( int i = 0 ; i < n ; i++){
        if(at[i] > time ){
            time = at[i];
        }
        time += bt[i];
        ct[i] = time ;
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
    }
    printf(" turnaround times are :");
    for(int i = 0 ; i < n ; i++){
        printf("%d ",tat[i]);
    }
    printf(" waiting times are :");
    for(int i = 0 ; i < n ; i++){
        printf("%d ",wt[i]);
    }
    return 0;
}
